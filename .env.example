# PictoMusic Environment Configuration
# Copy this file to .env and adjust values as needed.

# --- Model ---
# PICTOMUSIC_CLIP_MODEL=openai/clip-vit-base-patch32
# PICTOMUSIC_BATCH_SIZE=32
# PICTOMUSIC_MAX_TOKEN_LEN=77

# --- Recommendation ---
# PICTOMUSIC_TOP_K=10

# --- File paths (override only if needed) ---
# PICTOMUSIC_DATASET_PATH=
# PICTOMUSIC_EMBEDDINGS_PATH=

# --- Security ---
# PICTOMUSIC_MAX_UPLOAD_MB=10
# PICTOMUSIC_REQUEST_TIMEOUT=10
# PICTOMUSIC_MAX_URL_LEN=2048
